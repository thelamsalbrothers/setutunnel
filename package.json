{
  "name": "setutunnel-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "typecheck": "tsc -b --noEmit && tsc -p signaling/tsconfig.json --noEmit && tsc -p signaling/cloudflare/tsconfig.json --noEmit && tsc -p e2e/tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "format": "biome check --write ./src ./signaling ./scripts ./e2e ./playwright.config.ts",
    "format:check": "biome check ./src ./signaling ./scripts ./e2e ./playwright.config.ts",
    "dev:signaling": "bun signaling/server.ts",
    "signaling:smoke": "bun signaling/smoke.ts",
    "signaling:client-smoke": "bun signaling/client-smoke.ts",
    "signaling:cf:dev": "wrangler dev --config signaling/cloudflare/wrangler.toml",
    "signaling:cf:deploy": "wrangler deploy --config signaling/cloudflare/wrangler.toml",
    "pages:deploy": "wrangler pages deploy dist --project-name setutunnel",
    "test:e2e": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@tailwindcss/vite": "^4.3.2",
    "fflate": "^0.8.3",
    "motion": "^12.42.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@babel/core": "^7.29.7",
    "@biomejs/biome": "2.5.3",
    "@cloudflare/workers-types": "^5.20260713.1",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "axe-core": "^4.12.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxlint": "^1.73.0",
    "sharp": "^0.35.3",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.7",
    "wrangler": "^4.110.0"
  }
}
